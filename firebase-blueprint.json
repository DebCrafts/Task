{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "A task item",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "sharedWith": { 
          "type": "object",
          "description": "Map of userId to role ('edit' or 'view')"
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "completed": { "type": "boolean" },
        "dueDate": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "categoryId": { "type": "string" },
        "subtasks": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        },
        "reminder": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "updatedBy": { "type": "string" }
      },
      "required": ["ownerId", "title", "completed", "priority", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A task category",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "sharedWith": { 
          "type": "object",
          "description": "Map of userId to role ('edit' or 'view')"
        },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["ownerId", "name", "color", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Activity log for shared tasks",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["taskId", "userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories"
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "Activity logs"
    }
  }
}
